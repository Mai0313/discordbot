# Using OpenAI Endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Discord Bot Token
DISCORD_BOT_TOKEN=MTEz...

# Best-effort media kill-switches (default true). When false the answer model's marker is
# still stripped from the reply but no clip / image is produced.
VOICE_REPLY_ENABLED=true
INLINE_IMAGE_ENABLED=true
# When false a linked YouTube video is not watched (the QA turn falls back to the text path).
YOUTUBE_VIDEO_ENABLED=true
# When false the QA `<deep-research>` marker is stripped but no research thread is launched.
DEEP_RESEARCH_ENABLED=true
# When false the priciest Deep Research Max tier is hidden from the escalation buttons.
DEEP_RESEARCH_MAX_ENABLED=false
