# Using OpenAI Endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Google AI Studio key for the direct-to-Google paths (Veo video generation, Gemini Files
# API uploads, deep research). Not routed through the proxy.
GEMINI_API_KEY=AIza...

# Discord Bot Token
DISCORD_BOT_TOKEN=MTEz...

# Best-effort media kill-switches (default true). When false the answer model's marker is
# still stripped from the reply but no clip / image is produced.
INLINE_VOICE_ENABLED=true
INLINE_IMAGE_ENABLED=true
# When false the QA `<music>` marker is stripped but no music clip is generated (Lyria).
INLINE_MUSIC_ENABLED=true
# When false the QA `<video>` marker is stripped but no video clip is generated (omni).
INLINE_VIDEO_ENABLED=true
# When false a linked YouTube video is not watched (the QA turn falls back to the text path).
YOUTUBE_VIDEO_ENABLED=true
# When false the QA `<deep-research>` marker is stripped but no research thread is launched.
DEEP_RESEARCH_ENABLED=true
# When false the priciest Deep Research Max tier is hidden from the escalation buttons.
DEEP_RESEARCH_MAX_ENABLED=true
# When false the IMAGE-route request is sent to the image model as-is, with no prompt director
# refining it first (the inline `<generate-image>` marker never refines either way).
IMAGE_REFINE_PROMPT_ENABLED=true
# When false the VIDEO-route request is sent to the video model as-is, with no prompt director
# refining it first (the inline `<generate-video>` marker never refines either way).
VIDEO_REFINE_PROMPT_ENABLED=true

# External static media host: when a clip/file exceeds Discord's per-message upload limit
# (e.g. a long voice WAV in a DM, which has only a 10 MiB ceiling), the bot writes it under
# MEDIA_HOSTING_SERVE_DIR and posts MEDIA_HOSTING_BASE_URL/<name> instead of dropping it. The
# serve dir is bind-mounted from the host; nginx serves it with a strict extension allowlist.
# The bot never creates the serve dir: if it is absent it logs and falls back to native upload.
# Leave base_url / serve_dir empty to disable the fallback (media degrades exactly as before).
# Hosted files are content-addressed (identical content is stored once) and self-cleaned: the serve
# dir is bounded by both MEDIA_HOSTING_MAX_BYTES (oldest evicted past it; 8 GiB stays under R2's
# 10 GB free tier) and MEDIA_HOSTING_RETENTION_HOURS (older files reaped, cap or not). Either <=0
# disables that cap. The reaper only ever deletes the bot's own files, never anything else in the dir.
MEDIA_HOSTING_ENABLED=true
MEDIA_HOSTING_BASE_URL=https://media.mai0313.com
MEDIA_HOSTING_SERVE_DIR=/mnt/share/media
MEDIA_HOSTING_MAX_BYTES=8589934592
MEDIA_HOSTING_RETENTION_HOURS=168
